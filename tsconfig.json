{
  "compilerOptions": {
    "target": "es6",
    "lib": ["es6", "dom", "es2016", "esnext"],
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "typeRoots": [
      "./node_modules/@types",
      "./node_modules/@figma"
    ]
  },
  "include": ["code.ts", "experiment-info-card.ts", "load-fonts.ts"],
  "exclude": ["node_modules", "build", "ui.tsx", "components", "setupTests.ts"]
}
